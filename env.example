# ─────────────────────────────────────────────────────────────────
# RH Business OS — WhatsApp AI Bot v0.1
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Token you choose yourself when setting up the Meta webhook.
# Must match exactly what you enter in the Meta Developer Portal.
VERIFY_TOKEN=your_custom_verify_token_here

# Permanent access token from Meta Developer Portal
# (System User token or Page Access Token)
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here

# WhatsApp Phone Number ID from Meta Developer Portal
# Found at: App Dashboard → WhatsApp → API Setup
PHONE_NUMBER_ID=your_phone_number_id_here

# Path to the JSON file used to store incoming messages
MESSAGES_FILE=data/messages.json
